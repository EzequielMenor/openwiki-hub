# OpenWiki config — copied to ~/.openwiki/.env by install.sh
# The MiniMax API key is required; replace <YOUR_TOKEN> with the value from
# https://platform.minimax.io/user-center/payment/token-plan (token starts with sk-cp-)

OPENWIKI_PROVIDER="anthropic"
ANTHROPIC_API_KEY="<YOUR_MINIMAX_TOKEN>"
ANTHROPIC_BASE_URL="https://api.minimax.io/anthropic"
OPENWIKI_MODEL_ID="MiniMax-M3"